---
import { site } from '../data/site'

const base = import.meta.env.BASE_URL

const footerLinks = [
  { href: `${base}#main`, label: 'Home' },
  { href: `${base}#products`, label: 'Products' },
  { href: `${base}#contact`, label: 'Contact' },
]
---
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <img src={`${base}assets/logo.svg`} alt="MB Aukuris Lithuania" width="140" height="42" />
        <p>
          Laboratory equipment and healthcare technology for institutions across
          Lithuania and the region.
        </p>
      </div>

      <div>
        <p class="footer__heading">Quick Links</p>
        <ul class="footer__links">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="footer__heading">Contact</p>
        <p class="footer__contact-item">
          <a href={`tel:${site.phone}`}>+48 513 416 750</a>
        </p>
        <p class="footer__contact-item">
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
        <address class="footer__contact-item" style="font-style: normal;">
          {site.address.street}, {site.address.city}
        </address>
        <div class="footer__social">
          <a
            href="https://t.me/+48513416750/"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-icon"
            aria-label="Telegram"
          >
            <img src={`${base}assets/telegram.svg`} alt="" />
          </a>
          <a
            href="https://wa.me/+48513416750"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-icon"
            aria-label="WhatsApp"
          >
            <img src={`${base}assets/whatsapp.svg`} alt="" />
          </a>
        </div>
      </div>
    </div>

    <p class="footer-copyright">
      &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
    </p>
  </div>
</footer>
