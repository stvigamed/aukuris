<form action="#" id="form" class="form__body" novalidate>
  <h3 class="form-title">Request product information or pricing</h3>
  <div class="form__rows">
    <div class="form__row-first">
      <div class="form__item">
        <label class="form__label" for="formName">
          Name <abbr title="required">*</abbr>
        </label>
        <input
          type="text"
          id="formName"
          name="name"
          class="form__input _req"
          placeholder="Your full name"
          autocomplete="name"
          required
        />
      </div>
      <div class="form__item">
        <label class="form__label" for="formEmail">
          Email <abbr title="required">*</abbr>
        </label>
        <input
          type="email"
          id="formEmail"
          name="email"
          class="form__input _req _email"
          placeholder="you@company.com"
          autocomplete="email"
          required
        />
      </div>
      <div class="form__item">
        <label class="form__label" for="formCountry">Country</label>
        <input
          type="text"
          id="formCountry"
          name="country"
          class="form__input"
          placeholder="Lithuania"
          autocomplete="country-name"
        />
      </div>
    </div>
    <div class="form__row-second">
      <div class="form__item form-comment">
        <label class="form__label" for="formMessage">
          Message <abbr title="required">*</abbr>
        </label>
        <textarea
          id="formMessage"
          name="message"
          class="form__input _req"
          placeholder="Tell us about the products or equipment you need…"
          required
        ></textarea>
      </div>
      <button type="submit" class="btn btn--navy form__button">
        Send Message
      </button>
    </div>
  </div>
  <p class="form__status" id="formStatus" role="status" aria-live="polite"></p>
</form>

<script>
  const TELEGRAM_CHAT_ID = '-942161807'
  const TELEGRAM_BOT_TOKEN = '6029267965:AAEdlli5w6a8651AoMRRDQqTbdzPJPS-Sko'

  const form = document.getElementById('form')
  const statusEl = document.getElementById('formStatus')

  function showStatus(message, type) {
    if (!statusEl) return
    statusEl.textContent = message
    statusEl.className = `form__status form__status--${type}`
  }

  function clearStatus() {
    if (!statusEl) return
    statusEl.textContent = ''
    statusEl.className = 'form__status'
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault()
    clearStatus()

    const requiredFields = form.querySelectorAll('._req')
    let valid = true

    requiredFields.forEach((field) => {
      field.classList.remove('_error')
      if (!field.value.trim()) {
        field.classList.add('_error')
        valid = false
      }
    })

    const emailField = form.querySelector('._email')
    if (emailField?.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value)) {
      emailField.classList.add('_error')
      valid = false
    }

    if (!valid) {
      showStatus('Please fill in all required fields correctly.', 'error')
      return
    }

    form.classList.add('_sending')
    const submitBtn = form.querySelector('.form__button')
    if (submitBtn) submitBtn.textContent = 'Sending…'

    const formData = new FormData(form)
    const data = {}
    formData.forEach((value, key) => {
      data[key] = String(value)
    })

    fetch(`https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        chat_id: TELEGRAM_CHAT_ID,
        text: `
Name: ${data.name}
Email: ${data.email}
Country: ${data.country || '—'}
Message: ${data.message}

Sent: ${new Date().toLocaleString()}
        `.trim(),
      }),
    })
      .then((response) => {
        if (response.ok) {
          showStatus('Message sent! We will get back to you soon.', 'success')
          form.reset()
        } else {
          showStatus('Something went wrong. Please try again or contact us directly.', 'error')
        }
      })
      .catch(() => {
        showStatus('Something went wrong. Please try again or contact us directly.', 'error')
      })
      .finally(() => {
        form.classList.remove('_sending')
        if (submitBtn) submitBtn.textContent = 'Send Message'
      })
  })
</script>
