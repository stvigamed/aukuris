---
const base = import.meta.env.BASE_URL

const navItems = [
  { href: `${base}#main`, label: 'Home' },
  { href: `${base}#products`, label: 'Products' },
  { href: `${base}#contact`, label: 'Contact', cta: true },
]
---
<header class="header">
  <div class="container">
    <div class="header__row">
      <a href={`${base}#main`} class="header__logo" aria-label="Aukuris — back to home">
        <img src={`${base}assets/logo.svg`} alt="MB Aukuris Lithuania" width="140" height="42" />
      </a>

      <button
        class="menu-burger"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="site-nav"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="header-menu" id="site-nav" aria-label="Main navigation">
        <div class="header-menu__overlay" aria-hidden="true"></div>
        <div class="header-menu__panel">
          <ul class="header-menu__list">
            {navItems.map((item) => (
              <li class="header-menu__item">
                <a
                  href={item.href}
                  class:list={['header-menu__link', { 'header-menu__link--cta': item.cta }]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const burger = document.querySelector('.menu-burger')
  const menu = document.querySelector('.header-menu')
  const overlay = document.querySelector('.header-menu__overlay')
  const links = document.querySelectorAll('.header-menu__link')
  const sections = document.querySelectorAll('section[id]')

  function closeMenu() {
    burger?.classList.remove('active')
    menu?.classList.remove('active')
    burger?.setAttribute('aria-expanded', 'false')
    burger?.setAttribute('aria-label', 'Open menu')
    document.body.style.overflow = ''
  }

  function openMenu() {
    burger?.classList.add('active')
    menu?.classList.add('active')
    burger?.setAttribute('aria-expanded', 'true')
    burger?.setAttribute('aria-label', 'Close menu')
    document.body.style.overflow = 'hidden'
  }

  burger?.addEventListener('click', () => {
    if (menu?.classList.contains('active')) {
      closeMenu()
    } else {
      openMenu()
    }
  })

  overlay?.addEventListener('click', closeMenu)

  links.forEach((link) => {
    link.addEventListener('click', closeMenu)
  })

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu()
  })

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id')
          links.forEach((link) => {
            link.classList.toggle(
              'header-menu__link--active',
              link.getAttribute('href') === `#${id}`
            )
          })
        }
      })
    },
    { rootMargin: '-40% 0px -55% 0px' }
  )

  sections.forEach((section) => observer.observe(section))
</script>
