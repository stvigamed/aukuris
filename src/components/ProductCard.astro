---
const { logo, image, delay, logoAlt, imageAlt } = Astro.props
const base = import.meta.env.BASE_URL
---
<div
  class="product-container"
  data-aos="fade-up"
  data-aos-duration="500"
  data-aos-easing="linear"
  data-aos-delay={delay || undefined}
>
  <div class="product-logo">
    <img src={`${base}${logo}`} alt={logoAlt} loading="lazy" decoding="async" />
  </div>
  <div class="product-image-container">
    <img
      src={`${base}${image}`}
      class="product-image"
      alt={imageAlt}
      loading="lazy"
      decoding="async"
    />
  </div>
</div>
